---
import PhoneMockup from './PhoneMockup.astro';
---

<section class="relative overflow-hidden px-6 pt-8 pb-12 md:px-10 md:pt-24 md:pb-28 lg:px-14 lg:pt-12 lg:pb-16">
  <div class="hero-glow" aria-hidden="true"></div>

  <div class="relative mx-auto grid max-w-7xl items-center gap-12 lg:grid-cols-[1.1fr_1fr] lg:gap-16">
    <!-- Text content -->
    <div class="text-center lg:text-left">
      {/* Eyebrow rewrite candidates considered (foundation: parry-and-riposte craft framing). Unused alternates kept here for review:
           A: "the conversational craft assistant" — safer, App Store category-aligned, less distinctive
           E: "the back-and-forth, sharper" — metaphor at the verb level, but "sharper" is more figurative than brand voice usually allows */}
      <p class="eyebrow mb-6">your countermove for any message</p>

      <h1 class="font-display mb-6 text-balance font-semibold leading-[0.95]" style="font-size: var(--text-hero);">
        Never overthink<br />a message again.
      </h1>

      <p class="mx-auto mb-10 max-w-xl text-lg leading-relaxed text-text-secondary md:text-xl lg:mx-0">
        parry gives you the right reply for any message — any tone, any situation. Paste, pick, send.
      </p>

      <div class="flex flex-col items-center gap-4 lg:items-start">
        <div class="flex items-center gap-3 sm:gap-4">
          <a href="#download" class="inline-block transition-transform duration-200 hover:scale-105">
            <img src="/app-store-badge.svg" alt="Download on the App Store" width="160" height="54" />
          </a>
        </div>
        <p class="text-sm text-text-tertiary">
          Free to download. No account needed.
        </p>
      </div>
    </div>

    <!-- Phone preview -->
    <div class="flex justify-center lg:justify-end">
      <PhoneMockup />
    </div>
  </div>

  {/* Sentinel for the sticky mobile download bar — see MobileDownloadBar.astro. */}
  <div id="hero-sentinel" aria-hidden="true" class="absolute bottom-0 left-0 h-px w-px"></div>
</section>
