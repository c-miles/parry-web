---
/*
  Phone preview frame. Currently renders a static "screenshot-like" composition
  in CSS as a placeholder. When real app screenshots are ready (see issue #4),
  replace the entire <div class="phone-screen-content"> with an <img> tag —
  the frame, dimensions, and shadow stay the same.
*/
---

<div class="phone-frame" role="img" aria-label="parry app preview showing a witty reply suggestion">
  <!-- Outer frame (titanium-ish bezel). Height-driven sizing so the phone always
       fits the viewport on laptop screens (1280x800, 1440x900, etc.). Width
       derives from the 9/19.5 aspect ratio. -->
  <div
    class="relative mx-auto aspect-[9/19.5] w-auto"
    style="height: clamp(440px, 62dvh, 640px);"
  >
    <div
      class="relative h-full w-full rounded-[44px] p-[3px]"
      style="background: linear-gradient(155deg, #2a2530 0%, #1a1620 50%, #2a2530 100%); box-shadow: 0 30px 80px -20px rgba(0,0,0,0.6), 0 0 0 1px rgba(255,255,255,0.04);"
    >
      <div
        class="relative h-full w-full overflow-hidden rounded-[42px]"
        style="background: #0a070d;"
      >
        <!-- Notch -->
        <div class="absolute left-1/2 top-2.5 z-10 h-6 w-28 -translate-x-1/2 rounded-full bg-black"></div>

        <!-- TODO(issue #4): replace this entire block with <img src="/screenshots/hero.png" alt="..." class="h-full w-full object-cover" /> -->
        <div class="phone-screen-content flex h-full flex-col px-5 pt-12 pb-6">
          <!-- Status bar -->
          <div class="mb-6 flex items-center justify-between text-[11px] font-medium text-text-tertiary">
            <span>9:41</span>
            <div class="flex items-center gap-1">
              <div class="h-2.5 w-4 rounded-sm bg-text-tertiary"></div>
              <div class="h-2.5 w-2.5 rounded-sm bg-text-tertiary"></div>
            </div>
          </div>

          <!-- App brand -->
          <div class="mb-7 flex items-center justify-center gap-1.5">
            <span class="font-display text-sm font-semibold text-text-primary">parry</span>
          </div>

          <!-- Incoming message label -->
          <p class="eyebrow mb-2 text-[10px]">Their message</p>
          <div class="mb-5 rounded-2xl border border-hairline bg-bg-elevated p-3.5">
            <p class="text-[13px] leading-relaxed text-text-secondary">
              hey, I had a really great time last night :)
            </p>
          </div>

          <!-- Tone selector -->
          <p class="eyebrow mb-2 text-[10px]">Tone</p>
          <div class="mb-5 flex flex-wrap gap-1.5">
            <span class="rounded-full border border-hairline px-2.5 py-1 text-[11px] text-text-tertiary">Casual</span>
            <span class="rounded-full px-2.5 py-1 text-[11px] font-medium text-white" style="background: var(--color-accent);">Witty</span>
            <span class="rounded-full border border-hairline px-2.5 py-1 text-[11px] text-text-tertiary">Assertive</span>
          </div>

          <!-- Reply -->
          <p class="eyebrow mb-2 text-[10px]">parry says</p>
          <div class="rounded-2xl border border-hairline bg-bg-elevated p-3.5">
            <p class="text-[13px] leading-relaxed text-text-primary">
              same here. fair warning though — I'm already mentally ranking our next date spot options
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
