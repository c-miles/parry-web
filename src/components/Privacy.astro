---
const promises = [
  {
    title: "Never stored",
    body: "Messages are processed and gone. No logs, no databases, no backups."
  },
  {
    title: "Never trained on",
    body: "Your conversations are never used to train AI models. Your words stay yours."
  },
  {
    title: "Anonymous by default",
    body: "No account required. No email, no phone number. Just open and go."
  }
];
---

<section class="px-6 py-24 md:px-10 md:py-32 lg:px-14">
  <div class="mx-auto max-w-7xl">
    <div class="mb-16 max-w-2xl animate-on-scroll">
      <p class="eyebrow mb-5">Privacy</p>
      <h2 class="font-display text-balance font-semibold leading-[1.05]" style="font-size: var(--text-display);">
        Anonymous by design. Not by promise.
      </h2>
      <p class="mt-5 text-lg leading-relaxed text-text-secondary">
        Every message is processed in real-time and immediately forgotten. Nothing stored. Nothing trained on. Ever.
      </p>
    </div>

    <div class="grid gap-px bg-hairline sm:grid-cols-2 lg:grid-cols-3 animate-on-scroll" style="border-top: 1px solid var(--color-hairline); border-bottom: 1px solid var(--color-hairline);">
      {promises.map((p) => (
        <div class="bg-bg-base p-6 md:p-8">
          <p class="font-display mb-3 text-lg font-semibold tracking-tight">{p.title}</p>
          <p class="text-base leading-relaxed text-text-secondary">{p.body}</p>
        </div>
      ))}
    </div>

    <p class="mt-10 animate-on-scroll">
      <a href="/privacy" class="inline-flex items-center gap-2 text-base text-accent-text underline underline-offset-4 transition-colors hover:text-accent">
        Read our full privacy policy
        <span aria-hidden="true">&rarr;</span>
      </a>
    </p>
  </div>
</section>
