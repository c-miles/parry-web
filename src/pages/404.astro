---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found — Parry"
  description="The page you're looking for doesn't exist."
>
  <section class="flex min-h-[60vh] items-center justify-center px-5 py-16 md:px-8">
    <div class="text-center">
      <p class="mb-2 text-6xl font-bold text-text-tertiary">404</p>
      <h1 class="mb-4 font-[var(--font-sora)] text-2xl font-semibold md:text-3xl">
        Page not found
      </h1>
      <p class="mb-8 text-text-secondary">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <a href="/" class="gradient-button">
        Back to home
      </a>
    </div>
  </section>
</BaseLayout>
