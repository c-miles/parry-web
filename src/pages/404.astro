---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found — parry"
  description="The page you're looking for doesn't exist."
>
  <section class="flex min-h-[70dvh] items-center justify-center px-6 py-20 md:px-10">
    <div class="text-center">
      <p class="font-display mb-4 text-7xl font-semibold text-accent md:text-8xl" style="letter-spacing: -0.04em;">404</p>
      <h1 class="font-display mb-5 text-3xl font-semibold tracking-tight md:text-4xl">
        Page not found
      </h1>
      <p class="mx-auto mb-10 max-w-md text-lg text-text-secondary">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <a href="/" class="btn-primary">
        Back to home
      </a>
    </div>
  </section>
</BaseLayout>
